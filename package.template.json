{
  "name": "forecaswatch2",
  "author": "Matt Rossman",
  "version": "1.30.0",
  "buildProfile": "{{buildProfile}}",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "releaseNotification": {
    "enabled": true,
    "title": "New in v1.31.0!",
    "body": "The status bar now shows today's precipitation forecast. Flick your wrist to toggle between sun event time and precip amount.\n\nCustomize this in Settings → Weather → Status Bar Display."
  },
  "dependencies": {
    "suncalc": "^1.9.0"
  },
  "pebble": {
    "displayName": "{{displayName}}",
    "uuid": "{{uuid}}",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "diorite"
    ],
    "watchapp": {
      "watchface": true
    },
    "resources": {
      "media": [
        {
          "menuIcon": true,
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "icon.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_MUTE",
          "file": "img/mute.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_DISCONNECT",
          "file": "img/bt-disconnect.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_CONNECT",
          "file": "img/bt.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BATTERY_CHARGING",
          "file": "img/battery-charging.png",
          "memoryFormat": "1BitPalette"
        }
      ]
    },
    "capabilities": [
      "location",
      "configurable"
    ],
    "messageKeys": [
      "TEMP_TREND_INT16",
      "PRECIP_TREND_UINT8",
      "FORECAST_START",
      "NUM_ENTRIES",
      "CURRENT_TEMP",
      "CITY",
      "SUN_EVENTS",
      "PRECIP_TOTAL_UINT16",
      "PRECIP_TYPE_UINT8",
      "CLAY_CELSIUS",
      "CLAY_TIME_LEAD_ZERO",
      "CLAY_AXIS_12H",
      "CLAY_START_MON",
      "CLAY_COLOR_TODAY",
      "CLAY_PREV_WEEK",
      "CLAY_TIME_FONT",
      "CLAY_SHOW_QT",
      "CLAY_SHOW_BT",
      "CLAY_SHOW_BT_DISCONNECT",
      "CLAY_VIBE",
      "CLAY_SHOW_AM_PM",
      "CLAY_COLOR_SATURDAY",
      "CLAY_COLOR_SUNDAY",
      "CLAY_COLOR_US_FEDERAL",
      "CLAY_COLOR_TIME",
      "CLAY_DAY_NIGHT_SHADING",
      "CLAY_STATUS_BAR_MODE"
    ]
  }
}
