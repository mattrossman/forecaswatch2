# Phone IP used by `mise install-phone`
IP=192.168.1.100

# Supabase telemetry hash secret (generate with: openssl rand -hex 32)
TELEMETRY_HASH_SECRET=

# Optional telemetry build-time values injected into package.json by scripts/prepare-package.sh
# TELEMETRY_ENDPOINT=https://<your-project-ref>.supabase.co/functions/v1/telemetry-ingest
