{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "ask",
      "pebble": "allow"
    },
    "bash": {
      "mise build": "allow",
      "pebble logs *": "allow"
    },
    "supabase_search_docs": "allow",
    "supabase_list_tables": "allow",
    "supabase_list_extensions": "allow",
    "supabase_list_migrations": "allow",
    "supabase_get_logs": "allow",
    "supabase_get_advisors": "allow",
    "supabase_get_project_url": "allow",
    "supabase_get_publishable_keys": "allow",
    "supabase_generate_typescript_types": "deny", // Use CLI instead
    "supabase_apply_migration": "deny" // Use CLI instead
  },
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "http://localhost:54321/mcp",
      "enabled": true
    }
  }
}
